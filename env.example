BOT_TOKEN=BotFather_dan_olgan_tokeningizni_shu_yerga_yozing

# OpenSubtitles.com'dan olingan API key (subtitr qidirish/yuklash uchun)
# Ro'yxatdan o'tish: https://www.opensubtitles.com/en/consumers
OPENSUBTITLES_API_KEY=opensubtitles_api_keyingizni_shu_yerga_yozing

# Ixtiyoriy: OpenSubtitles akkauntingiz (kunlik limitni 5 dan 20 taga oshiradi)
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=

# Anthropic (Claude) API key — subtitr tarjimasi uchun
# Olish: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=anthropic_api_keyingizni_shu_yerga_yozing
